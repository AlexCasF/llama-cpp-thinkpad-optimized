# Full model context. q4 KV is a quality/memory tradeoff; use balanced for normal
# production with VMware guests unless the extra context is actually needed.
CTX_SIZE=262144
N_GPU_LAYERS=99
N_CPU_MOE=36
THREADS=6
THREADS_BATCH=7
BATCH_SIZE=1024
UBATCH_SIZE=1024
CACHE_TYPE_K=q4_0
CACHE_TYPE_V=q4_0
FLASH_ATTN=on
N_PARALLEL=1
CACHE_RAM_MIB=128
CACHE_REUSE=256
REQUEST_TIMEOUT_SECONDS=86400
LLAMA_NO_MMAP=0
LLAMA_MLOCK=0
