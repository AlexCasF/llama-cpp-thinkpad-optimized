# Recommended daily profile: substantial context with q4 KV to preserve RAM
# for Windows, Chrome, and VMware guests.
CTX_SIZE=131072
N_GPU_LAYERS=99
N_CPU_MOE=36
THREADS=6
THREADS_BATCH=7
BATCH_SIZE=1024
UBATCH_SIZE=1024
CACHE_TYPE_K=q4_0
CACHE_TYPE_V=q4_0
FLASH_ATTN=on
N_PARALLEL=1
CACHE_RAM_MIB=256
CACHE_REUSE=256
REQUEST_TIMEOUT_SECONDS=86400
LLAMA_NO_MMAP=0
LLAMA_MLOCK=0
