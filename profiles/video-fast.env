# Video-style experiment: disable mmap to test whether avoiding page faults
# helps this machine. This uses more memory and is not the safe default.
CTX_SIZE=65536
N_GPU_LAYERS=99
N_CPU_MOE=28
THREADS=6
THREADS_BATCH=7
BATCH_SIZE=2048
UBATCH_SIZE=1024
CACHE_TYPE_K=q8_0
CACHE_TYPE_V=q8_0
FLASH_ATTN=auto
N_PARALLEL=1
CACHE_RAM_MIB=256
CACHE_REUSE=256
REQUEST_TIMEOUT_SECONDS=86400
LLAMA_NO_MMAP=1
LLAMA_MLOCK=0
