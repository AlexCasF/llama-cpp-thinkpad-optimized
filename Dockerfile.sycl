ARG LLAMA_IMAGE=ghcr.io/ggml-org/llama.cpp:full-intel
FROM ${LLAMA_IMAGE}

USER root
COPY docker/server-entrypoint.sh /usr/local/bin/llama-server-tuned
COPY docker/tune-entrypoint.sh /usr/local/bin/tune-qwen36
RUN chmod 0755 /usr/local/bin/llama-server-tuned /usr/local/bin/tune-qwen36

ENTRYPOINT ["/usr/local/bin/llama-server-tuned"]
